#!/bin/bash
DIR="$(cd "$(dirname "$0")" && pwd)"

# Start the server in background
"$DIR/risco-control" &
SERVER_PID=$!

# Wait for server to be ready
for i in {1..30}; do
    curl -s http://localhost:3580/api/system > /dev/null 2>&1 && break
    sleep 1
done

# Open browser
open "http://localhost:3580"

# Keep running until server dies
wait $SERVER_PID
